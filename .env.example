# SearxNG configuration
SEARXNG_HOST=http://searxng:8080
SEARXNG_ENGINES=google,duckduckgo,bing,wikipedia,startpage,brave,qwant,yahoo
SEARXNG_DEFAULT_CATEGORY=general
SEARXNG_SAFESEARCH=0
SEARXNG_SECRET=change-me-to-a-random-string

# MCP Server
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000

# Optional API key for MCP server protection (leave empty to disable)
API_KEY=

# Search settings
SEARCH_DEFAULT_TYPE=auto  # instant, fast, auto, deep_lite, deep, deep_reasoning
SEARCH_DEFAULT_LIMIT=10
SEARCH_TIMEOUT_SECONDS=10

# Fetcher settings
FETCH_TIMEOUT_SECONDS=15
FETCH_MAX_CONTENT_LENGTH=10000
FETCH_TOKEN_BUDGET=8000
